{
    "expo": {
        "name": "FlyGift",
        "slug": "flygift",
        "version": "0.1.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "scheme": "flygift",
        "userInterfaceStyle": "dark",
        "splash": {
            "image": "./assets/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#070B1A"
        },
        "ios": {
            "supportsTablet": false,
            "bundleIdentifier": "com.flygift.app",
            "infoPlist": {
                "ITSAppUsesNonExemptEncryption": false
            }
        },
        "android": {
            "package": "com.flygift.app",
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#070B1A"
            }
        },
        "web": {
            "bundler": "metro"
        },
        "plugins": [
            "expo-secure-store",
            [
                "expo-splash-screen",
                {
                    "backgroundColor": "#070B1A",
                    "image": "./assets/splash.png",
                    "imageWidth": 200
                }
            ]
        ],
        "extra": {
            "webUrl": "https://app.flygift.com"
        }
    }
}