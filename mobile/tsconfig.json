{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "strict": true,
        "jsx": "react-native",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": [
            "react-native"
        ]
    },
    "include": [
        "**/*.ts",
        "**/*.tsx"
    ]
}