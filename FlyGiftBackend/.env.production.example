# Production environment variables — copy this file, fill in real values,
# and load via your hosting provider (Docker secrets, Azure App Settings,
# AWS Parameter Store, fly.io secrets, etc.). Never commit the filled file.
#
# ASP.NET Core reads any colon-separated config key as `__`-separated
# env var, so JwtSettings:Secret == JwtSettings__Secret.

# --- Database ----------------------------------------------------------
ConnectionStrings__FlyGiftDatabase=Host=...-pooler....neon.tech;Database=...;Username=...;Password=...;Ssl Mode=Require;Minimum Pool Size=1;Timeout=15;Command Timeout=15;Keepalive=30

# --- JWT ---------------------------------------------------------------
# Generate fresh with: openssl rand -base64 32
JwtSettings__Secret=
JwtSettings__Audience=https://app.flygift.app
JwtSettings__Issuer=FlyGiftBackend

# --- Stripe ------------------------------------------------------------
Stripe__SecretKey=sk_live_...
Stripe__PublishableKey=pk_live_...
Stripe__WebhookSecret=whsec_...

# --- Kiwi.com Tequila --------------------------------------------------
Travel__Kiwi__ApiKey=
Travel__Kiwi__Mode=Production

# --- Messaging ---------------------------------------------------------
Messaging__SendGrid__ApiKey=SG....
Messaging__Twilio__AccountSid=AC...
Messaging__Twilio__AuthToken=

# --- Hosting -----------------------------------------------------------
Hosting__PublicBaseUrl=https://api.flygift.app

# --- Auth cookie -------------------------------------------------------
Auth__Cookie__SameSite=Strict
Auth__Cookie__Secure=true
# Set Domain for sub-domain sharing (e.g. .flygift.app). Empty = host-only.
Auth__Cookie__Domain=

# --- CORS --------------------------------------------------------------
Cors__AllowedOrigins=https://app.flygift.app

# --- Apple Wallet (PassKit) --------------------------------------------
# Required for iOS to accept .pkpass files. Without these, the API returns
# 503 instead of an unsigned bundle (which Safari rejects).
#
# 1. Enroll in Apple Developer Program ($99/yr)
# 2. Create Pass Type ID: pass.com.flygift.boardingpass
# 3. Create Pass Type ID Certificate → export as .p12
# 4. Download Apple WWDR G4 intermediate cert (PEM/DER)
# 5. Upload both to the server and set paths below
Wallet__Apple__PassTypeIdentifier=pass.com.flygift.boardingpass
Wallet__Apple__TeamIdentifier=
Wallet__Apple__OrganizationName=FlyGift
Wallet__Apple__CertPath=/opt/flygift/secrets/apple-pass.p12
Wallet__Apple__CertPassword=
Wallet__Apple__WwdrCertPath=/opt/flygift/secrets/AppleWWDRCAG4.cer
# Never set true in production — unsigned passes fail on real iPhones.
Wallet__AllowUnsigned=false
