# ============================================================
# FlyGift backend (.NET) — copy to appsettings.Development.json
# overrides or set as environment variables.
# ============================================================

# --- Database ---
ConnectionStrings__FlyGiftDatabase="Server=localhost;Database=FlyGiftDb;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=True"

# --- JWT (must be 32+ random chars) ---
JwtSettings__Secret="REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS"
JwtSettings__Issuer="FlyGift"
JwtSettings__Audience="FlyGiftClients"
JwtSettings__ExpirationHours="24"

# --- CORS allow-list (comma-separated origins) ---
# Read by Program.cs CORS policy. Update Program.cs if you swap to env-driven.
# Default code allows http://localhost:3000.

# --- Hosting ---
ASPNETCORE_ENVIRONMENT="Development"
ASPNETCORE_URLS="http://localhost:5050"

# --- Optional: distributed cache for IIdempotencyService ---
# Redis__ConnectionString="localhost:6379"
